rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Connectivity test path
    match /test/connection {
      allow read: if true; // Publicly readable for connectivity checks
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() <= 100
          && data.points is number
          && (data.role == 'general' || data.role == 'farm_owner' || data.role == 'gov_admin');
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.role == resource.data.role; // Role is immutable
    }
  }
}
